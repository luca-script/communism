{
    "name": "luca-script/communism",
    "description": "Communism.",
    "type": "project",
    "license": "0BSD",
    "require": {
        "php": "^8.4",
        "ext-ffi": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Communism\\": "src/Communism/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Communism\\Ext\\": "ext/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix",
        "format:check": "php-cs-fixer fix --dry-run --diff",
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
